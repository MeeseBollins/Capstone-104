/*
 * Wheat Milling Metal Detector - Continuous Logging Version
 * Logic: Multiplexer addressing using explicit IF/SWITCH statements.
 */

// --- Pin Definitions ---
const int S0         = 8;   
const int S1         = 9;   
const int SIG_PIN    = A0;  
const int ALARM_PIN  = 13;  

// --- Sensitivity & Timing ---
const int   NUM_CHANNELS     = 4;
const float VREF             = 3.3;   
const float SPIKE_DELTA      = 0.20;  // High sensitivity for 3cm gap
const int   CAL_SAMPLES      = 64;
const unsigned long ALARM_ON_TIME = 500; 

// --- Runtime State ---
float baseline[NUM_CHANNELS];
float threshold[NUM_CHANNELS];
unsigned long lastAlarmTime = 0;
unsigned long lastHeartbeat = 0;

// ─── REWRITTEN SELECTION LOGIC ───
// This function replaces the bitwise math with explicit pin states.
void selectChannel(int ch) {
  if (ch == 0) {
    digitalWrite(S1, LOW);  // Binary 00
    digitalWrite(S0, LOW);
  } 
  else if (ch == 1) {
    digitalWrite(S1, LOW);  // Binary 01
    digitalWrite(S0, HIGH);
  } 
  else if (ch == 2) {
    digitalWrite(S1, HIGH); // Binary 10
    digitalWrite(S0, LOW);
  } 
  else if (ch == 3) {
    digitalWrite(S1, HIGH); // Binary 11
    digitalWrite(S0, HIGH);
  }
}

void setup() {
  pinMode(S0, OUTPUT);
  pinMode(S1, OUTPUT);
  pinMode(ALARM_PIN, OUTPUT);
  
  Serial.begin(115200);
  while (!Serial); 

  Serial.println("--- INITIALIZING CONTINUOUS MONITORING (IF-LOGIC) ---");
  calibrate();
}

void loop() {
  for (int i = 0; i < NUM_CHANNELS; i++) {
    selectChannel(i);
    delayMicroseconds(150); // Increased settle time for reliability

    float volts = (analogRead(SIG_PIN) * VREF) / 1023.0;

    if (volts >= threshold[i]) {
      logDetection(i + 1, volts);
    }
    
    delay(1); 
  }

  if (millis() - lastAlarmTime >= ALARM_ON_TIME) {
    digitalWrite(ALARM_PIN, LOW);
  }

  if (millis() - lastHeartbeat >= 2000) {
    Serial.println("[SYSTEM] Monitoring stream... OK");
    lastHeartbeat = millis();
  }
}

void calibrate() {
  Serial.println("Establishing baselines...");
  for (int ch = 0; ch < NUM_CHANNELS; ch++) {
    selectChannel(ch);
    delay(50);

    double sum = 0;
    for (int s = 0; s < CAL_SAMPLES; s++) {
      sum += (analogRead(SIG_PIN) * VREF) / 1023.0;
      delay(2);
    }
    baseline[ch] = (float)(sum / CAL_SAMPLES);
    threshold[ch] = baseline[ch] + SPIKE_DELTA;

    Serial.print("Sensor "); Serial.print(ch + 1);
    Serial.print(" Baseline: "); Serial.print(baseline[ch], 3);
    Serial.print("V | Threshold: "); Serial.println(threshold[ch], 3);
  }
  Serial.println("--- MONITORING ACTIVE ---");
}

void logDetection(int sensorNum, float value) {
  digitalWrite(ALARM_PIN, HIGH);
  lastAlarmTime = millis();

  Serial.print("[EVENT] ");
  Serial.print(millis() / 1000.0, 2);
  Serial.print("s | METAL DETECTED | Sensor: ");
  Serial.print(sensorNum);
  Serial.print(" | Voltage: ");
  Serial.print(value, 3);
  Serial.println("V");
}
